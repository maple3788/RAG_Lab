# Copy to .env and fill in (never commit .env)
GEMINI_API_KEY=

# Optional: OpenAI-compatible API when using --llm-backend openai
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional: Ollama when using --llm-backend ollama (default http://127.0.0.1:11434/v1)
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# Ingest pipeline (demo/app.py → workflow "Ingest"): AiStor + Redis via docker compose
# docker compose up -d
#
# Match `mc alias`: endpoint host:port only (no https://). Use SSL flags for https://localhost:9000
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_USE_SSL=true
# MINIO_CERT_CHECK=false
# MINIO_BUCKET=rag-lab-ingest
# REDIS_URL=redis://localhost:6379/0
